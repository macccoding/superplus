{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "DATABASE_URL",
    "NEXTAUTH_SECRET",
    "NEXTAUTH_URL",
    "BLOB_READ_WRITE_TOKEN",
    "NEXT_PUBLIC_VAPID_PUBLIC_KEY",
    "VAPID_PRIVATE_KEY",
    "VAPID_SUBJECT",
    "CRON_SECRET",
    "SUPERPLUS_DATABASE_URL",
    "SUPERPLUS_DATABASE_URL_UNPOOLED",
    "SUPERPLUS_NEON_AUTH_BASE_URL",
    "SUPERPLUS_NEON_PROJECT_ID",
    "SUPERPLUS_PGDATABASE",
    "SUPERPLUS_PGHOST",
    "SUPERPLUS_PGHOST_UNPOOLED",
    "SUPERPLUS_PGPASSWORD",
    "SUPERPLUS_PGUSER",
    "SUPERPLUS_POSTGRES_DATABASE",
    "SUPERPLUS_POSTGRES_HOST",
    "SUPERPLUS_POSTGRES_PASSWORD",
    "SUPERPLUS_POSTGRES_PRISMA_URL",
    "SUPERPLUS_POSTGRES_URL",
    "SUPERPLUS_POSTGRES_URL_NO_SSL",
    "SUPERPLUS_POSTGRES_URL_NON_POOLING",
    "SUPERPLUS_POSTGRES_USER",
    "SUPERPLUS_VITE_NEON_AUTH_URL"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "db:generate": {
      "cache": false
    },
    "db:push": {
      "cache": false
    },
    "db:seed": {
      "cache": false
    }
  }
}
