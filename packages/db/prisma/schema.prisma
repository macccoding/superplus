generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  MANAGER
  SUPERVISOR
  STAFF
}

enum JobLane {
  SUPERVISOR
  PRICING_CLERK
  CASHIER
  PRODUCE_MEAT
  MERCHANDISER
}

enum ThreadCategory {
  GENERAL
  URGENT
  MAINTENANCE
  INVENTORY
  OTHER
}

enum ThreadType {
  PUBLIC
  CHANNEL
  DIRECT
}

enum ThreadAttachmentType {
  IMAGE
  DOCUMENT
  LINK
}

enum ThreadReactionType {
  ACK
  THANKS
}

enum ThreadModerationAction {
  MESSAGE_EDITED
  MESSAGE_DELETED
  MESSAGE_PINNED
  MESSAGE_UNPINNED
  THREAD_PINNED
  THREAD_UNPINNED
  THREAD_RESOLVED
  TASK_CREATED
}

enum ThreadLifecycleEventType {
  URGENT_UNACKED_REMINDER
  NO_REPLY_FLAGGED
  STALE_RESOLVE_SUGGESTED
  OPS_SUGGESTION_DISMISSED
}

enum Priority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  NEEDS_HELP
  IN_REVIEW
  DONE
  CANCELLED
}

enum TaskUpdateType {
  CREATED
  NOTE
  HELP_REQUESTED
  HELP_RESOLVED
  STATUS_CHANGED
  REASSIGNED
  COMPLETION
  SUBMITTED_REVIEW
  APPROVED
  SENT_BACK
  CANCELLED
  CHECKLIST_UPDATED
  ATTACHMENT_ADDED
}

enum TaskAttachmentType {
  IMAGE
  DOCUMENT
  LINK
}

enum LogEntryAttachmentType {
  IMAGE
  DOCUMENT
  VIDEO
}

enum TaskLinkType {
  TASK
  INCIDENT
  LOGBOOK
  CHECKLIST
  PRODUCT
  STOCK_OUT
  EXPIRY_ALERT
  PURCHASE_ORDER
  SOP_GUIDE
  THREAD
  OTHER
}

enum LogCategory {
  GENERAL
  INCIDENT
  HANDOVER
  INVENTORY
}

enum AnnouncePriority {
  NORMAL
  IMPORTANT
  CRITICAL
}

model Store {
  id        String   @id @default(cuid())
  name      String
  parish    String
  address   String
  phone     String?
  openTime  String?
  closeTime String?
  openDays  String?
  launchEnabled Boolean  @default(false)
  launchedAt    DateTime?
  launchNotes   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  users                User[]
  threads              Thread[]
  tasks                Task[]
  taskTemplates        TaskTemplate[]
  logEntries           LogEntry[]
  announcements        Announcement[]
  categories           Category[]
  products             Product[]
  checklistTemplates   ChecklistTemplate[]
  checklistSubmissions ChecklistSubmission[]
  expiryAlerts         ExpiryAlert[]
  stockOutReports      StockOutReport[]
  incidents            Incident[]
  shiftSchedules       ShiftSchedule[]
  staffAbsences        StaffAbsence[]
  suppliers            Supplier[]
  orders               PurchaseOrder[]
  promotions           Promotion[]
  sopGuides            SOPGuide[]
  suggestions          Suggestion[]
  adminActionLogs      AdminActionLog[]
}

model User {
  id        String   @id @default(cuid())
  storeId   String
  fullName  String
  phone     String   @unique
  pinHash   String
  role      Role     @default(STAFF)
  jobLane   JobLane  @default(CASHIER)
  email     String?  @unique
  avatarUrl String?
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  mustChangePin     Boolean  @default(false)
  pinChangedAt      DateTime?
  onboardedAt       DateTime?
  onboardingVersion Int      @default(0)
  preferredName     String?
  birthdayMonth     Int?
  birthdayDay       Int?
  favoriteColor     String?
  favoriteTreat     String?
  dreamGoal         String?
  proudMoment       String?
  learningInterest  String?
  celebrationPreference String?
  showBirthday      Boolean  @default(true)
  profileUpdatedAt  DateTime?

  store                Store               @relation(fields: [storeId], references: [id])
  createdThreads       Thread[]            @relation("ThreadAuthor")
  resolvedThreads      Thread[]            @relation("ThreadResolver")
  lastThreadMessages   Thread[]            @relation("ThreadLastMessage")
  threadMessages       ThreadMessage[]
  deletedThreadMessages ThreadMessage[]     @relation("ThreadMessageDeleter")
  threadParticipants   ThreadParticipant[]
  threadMentions       ThreadMention[]
  threadAttachments    ThreadMessageAttachment[]
  threadReactions      ThreadMessageReaction[]
  threadModerationEvents ThreadModerationEvent[]
  pushSubscriptions    PushSubscription[]
  notificationPreference NotificationPreference?
  threadLifecycleEvents ThreadLifecycleEvent[]
  createdTasks         Task[]              @relation("TaskCreator")
  assignedTasks        Task[]              @relation("TaskAssignee")
  reviewedTasks        Task[]              @relation("TaskReviewer")
  taskUpdates          TaskUpdate[]
  completedTaskItems   TaskChecklistItem[] @relation("TaskItemCompleter")
  taskAttachments      TaskAttachment[]
  taskTemplates        TaskTemplate[]      @relation("TaskTemplateCreator")
  logEntries           LogEntry[]
  resolvedLogEntries   LogEntry[]          @relation("LogEntryResolver")
  logEntryReads        LogEntryRead[]
  logEntryComments     LogEntryComment[]
  logEntryAttachments  LogEntryAttachment[]
  announcements        Announcement[]
  announcementReceipts AnnouncementReceipt[]
  checklistSubmissions ChecklistSubmission[]
  expiryAlerts         ExpiryAlert[]    @relation("ExpiryReporter")
  stockOutsReported    StockOutReport[] @relation("StockOutReporter")
  stockOutsResolved    StockOutReport[] @relation("StockOutResolver")
  incidentsReported    Incident[]       @relation("IncidentReporter")
  incidentsResolved    Incident[]       @relation("IncidentResolver")
  staffAvailability    StaffAvailability[]
  staffAbsences        StaffAbsence[]     @relation("StaffAbsenceUser")
  createdStaffAbsences StaffAbsence[]     @relation("StaffAbsenceCreator")
  shiftSlots           ShiftSlot[]
  publishedSchedules   ShiftSchedule[]  @relation("SchedulePublisher")
  createdOrders        PurchaseOrder[]  @relation("POCreator")
  createdPromotions    Promotion[]      @relation("PromotionCreator")
  createdSOPGuides     SOPGuide[]       @relation("SOPCreator")
  suggestions          Suggestion[]     @relation("SuggestionAuthor")
  suggestionResponses  Suggestion[]     @relation("SuggestionResponder")
  notifications        Notification[]
  adminActionLogs      AdminActionLog[] @relation("AdminActionActor")
  updatedAppSettings   AppSetting[]     @relation("AppSettingUpdater")

  @@index([storeId])
  @@index([phone])
}

model Thread {
  id              String         @id @default(cuid())
  storeId         String
  authorId        String
  title           String
  type            ThreadType     @default(PUBLIC)
  defaultKey      String?
  category        ThreadCategory @default(GENERAL)
  isPinned        Boolean        @default(false)
  isResolved      Boolean        @default(false)
  resolvedAt      DateTime?
  resolvedById    String?
  lastMessageAt   DateTime?
  lastMessageById String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  store         Store               @relation(fields: [storeId], references: [id])
  author        User                @relation("ThreadAuthor", fields: [authorId], references: [id])
  resolvedBy    User?               @relation("ThreadResolver", fields: [resolvedById], references: [id])
  lastMessageBy User?               @relation("ThreadLastMessage", fields: [lastMessageById], references: [id])
  messages      ThreadMessage[]
  participants  ThreadParticipant[]
  mentions      ThreadMention[]
  links         ThreadLink[]
  moderationEvents ThreadModerationEvent[]
  lifecycleEvents ThreadLifecycleEvent[]

  @@index([storeId, createdAt])
  @@index([storeId, isResolved, updatedAt])
  @@index([storeId, lastMessageAt])
  @@index([storeId, type])
  @@unique([storeId, defaultKey])
}

model ThreadMessage {
  id          String   @id @default(cuid())
  threadId    String
  authorId    String
  body        String
  isPinned    Boolean  @default(false)
  editedAt    DateTime?
  deletedAt   DateTime?
  deletedById String?
  createdAt   DateTime @default(now())

  thread      Thread                    @relation(fields: [threadId], references: [id], onDelete: Cascade)
  author      User                      @relation(fields: [authorId], references: [id])
  deletedBy   User?                     @relation("ThreadMessageDeleter", fields: [deletedById], references: [id])
  mentions    ThreadMention[]
  attachments ThreadMessageAttachment[]
  reactions   ThreadMessageReaction[]
  links       ThreadLink[]
  moderationEvents ThreadModerationEvent[]

  @@index([threadId, createdAt])
  @@index([threadId, isPinned])
  @@index([authorId, createdAt])
}

model ThreadParticipant {
  id          String    @id @default(cuid())
  threadId    String
  userId      String
  lastReadAt  DateTime?
  isFollowing Boolean   @default(true)
  isSaved     Boolean   @default(false)
  mutedAt     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, isSaved])
  @@index([userId, lastReadAt])
}

model ThreadMention {
  id        String   @id @default(cuid())
  threadId  String
  messageId String
  userId    String
  createdAt DateTime @default(now())

  thread  Thread        @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message ThreadMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId])
  @@index([threadId, userId])
}

model ThreadMessageAttachment {
  id           String               @id @default(cuid())
  messageId    String
  uploadedById String
  type         ThreadAttachmentType
  url          String
  label        String?
  mimeType     String?
  sizeBytes    Int?
  storageKey   String?
  createdAt    DateTime             @default(now())

  message    ThreadMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  uploadedBy User          @relation(fields: [uploadedById], references: [id])

  @@index([messageId, createdAt])
}

model ThreadModerationEvent {
  id        String                 @id @default(cuid())
  threadId  String
  messageId String?
  actorId   String
  action    ThreadModerationAction
  note      String?
  metadata  Json?
  createdAt DateTime               @default(now())

  thread Thread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message ThreadMessage? @relation(fields: [messageId], references: [id], onDelete: SetNull)
  actor  User           @relation(fields: [actorId], references: [id])

  @@index([threadId, createdAt])
  @@index([messageId])
  @@index([actorId, createdAt])
}

model ThreadLifecycleEvent {
  id        String                   @id @default(cuid())
  threadId  String
  actorId   String?
  type      ThreadLifecycleEventType
  messageId String?
  metadata  Json?
  createdAt DateTime                 @default(now())

  thread Thread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  actor  User?  @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([threadId, type, createdAt])
  @@index([actorId, createdAt])
}

model ThreadMessageReaction {
  id        String             @id @default(cuid())
  messageId String
  userId    String
  type      ThreadReactionType
  createdAt DateTime           @default(now())

  message ThreadMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, type])
  @@index([messageId, type])
}

model ThreadLink {
  id        String       @id @default(cuid())
  threadId  String
  messageId String?
  type      TaskLinkType
  entityId  String
  label     String?
  createdAt DateTime     @default(now())

  thread  Thread         @relation(fields: [threadId], references: [id], onDelete: Cascade)
  message ThreadMessage? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([messageId])
  @@index([type, entityId])
}

model Task {
  id                     String     @id @default(cuid())
  storeId                String
  title                  String
  description            String?
  category               String?
  workArea               String?
  assetLabel             String?
  createdById            String
  assignedToId           String?
  reviewedById           String?
  priority               Priority   @default(NORMAL)
  status                 TaskStatus @default(OPEN)
  startDate              DateTime?
  dueDate                DateTime?
  dueReminderAt          DateTime?
  reviewRequired         Boolean    @default(false)
  requireCompletionNote  Boolean    @default(false)
  requireCompletionPhoto Boolean    @default(false)
  helpRequestedAt        DateTime?
  helpResolvedAt         DateTime?
  completionNote         String?
  submittedForReviewAt   DateTime?
  reviewedAt             DateTime?
  completedAt            DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @default(now()) @updatedAt

  store          Store               @relation(fields: [storeId], references: [id])
  createdBy      User                @relation("TaskCreator", fields: [createdById], references: [id])
  assignedTo     User?               @relation("TaskAssignee", fields: [assignedToId], references: [id])
  reviewedBy     User?               @relation("TaskReviewer", fields: [reviewedById], references: [id])
  updates        TaskUpdate[]
  checklistItems TaskChecklistItem[]
  attachments    TaskAttachment[]
  links          TaskLink[]

  @@index([storeId, status])
  @@index([assignedToId, status])
  @@index([storeId, dueDate])
  @@index([storeId, workArea])
}

model TaskUpdate {
  id         String         @id @default(cuid())
  taskId     String
  authorId   String
  type       TaskUpdateType @default(NOTE)
  body       String?
  fromStatus TaskStatus?
  toStatus   TaskStatus?
  createdAt  DateTime       @default(now())

  task   Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author User @relation(fields: [authorId], references: [id])

  @@index([taskId, createdAt])
}

model TaskChecklistItem {
  id            String    @id @default(cuid())
  taskId        String
  label         String
  sortOrder     Int       @default(0)
  isRequired    Boolean   @default(true)
  isDone        Boolean   @default(false)
  completedAt   DateTime?
  completedById String?

  task        Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedBy User? @relation("TaskItemCompleter", fields: [completedById], references: [id])

  @@index([taskId, sortOrder])
}

model TaskAttachment {
  id           String             @id @default(cuid())
  taskId       String
  uploadedById String
  type         TaskAttachmentType
  url          String
  label        String?
  createdAt    DateTime           @default(now())

  task       Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  uploadedBy User @relation(fields: [uploadedById], references: [id])

  @@index([taskId, createdAt])
}

model TaskLink {
  id        String       @id @default(cuid())
  taskId    String
  type      TaskLinkType
  entityId  String
  label     String?
  createdAt DateTime     @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([type, entityId])
}

model TaskTemplate {
  id                     String   @id @default(cuid())
  storeId                String
  title                  String
  description            String?
  category               String?
  defaultWorkArea        String?
  defaultAssetLabel      String?
  priority               Priority @default(NORMAL)
  reviewRequired         Boolean  @default(false)
  requireCompletionNote  Boolean  @default(false)
  requireCompletionPhoto Boolean  @default(false)
  recurrenceRule         String?
  isActive               Boolean  @default(true)
  createdById            String
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  store     Store              @relation(fields: [storeId], references: [id])
  createdBy User               @relation("TaskTemplateCreator", fields: [createdById], references: [id])
  items     TaskTemplateItem[]

  @@index([storeId, isActive])
  @@index([storeId, category])
}

model TaskTemplateItem {
  id         String  @id @default(cuid())
  templateId String
  label      String
  sortOrder  Int     @default(0)
  isRequired Boolean @default(true)

  template TaskTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId, sortOrder])
}

model LogEntry {
  id           String      @id @default(cuid())
  storeId      String
  authorId     String
  date         DateTime    @db.Date
  body         String
  category     LogCategory @default(GENERAL)
  isFlagged    Boolean     @default(false)
  resolvedAt   DateTime?
  resolvedById String?
  createdAt    DateTime    @default(now())

  store      Store          @relation(fields: [storeId], references: [id])
  author     User           @relation(fields: [authorId], references: [id])
  resolvedBy User?          @relation("LogEntryResolver", fields: [resolvedById], references: [id])
  reads      LogEntryRead[]
  comments   LogEntryComment[]
  attachments LogEntryAttachment[]
  links      LogEntryLink[]

  @@index([storeId, date])
  @@index([storeId, isFlagged, resolvedAt])
}

model LogEntryRead {
  id         String   @id @default(cuid())
  logEntryId String
  userId     String
  readAt     DateTime @default(now())

  logEntry LogEntry @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([logEntryId, userId])
  @@index([userId, readAt])
}

model LogEntryComment {
  id         String   @id @default(cuid())
  logEntryId String
  authorId   String
  body       String
  createdAt  DateTime @default(now())

  logEntry LogEntry @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
  author   User     @relation(fields: [authorId], references: [id])

  @@index([logEntryId, createdAt])
}

model LogEntryAttachment {
  id           String                 @id @default(cuid())
  logEntryId   String
  uploadedById String
  type         LogEntryAttachmentType @default(IMAGE)
  url          String
  label        String?
  createdAt    DateTime               @default(now())

  logEntry   LogEntry @relation(fields: [logEntryId], references: [id], onDelete: Cascade)
  uploadedBy User     @relation(fields: [uploadedById], references: [id])

  @@index([logEntryId, createdAt])
}

model LogEntryLink {
  id         String       @id @default(cuid())
  logEntryId String
  type       TaskLinkType
  entityId   String
  label      String?
  createdAt  DateTime     @default(now())

  logEntry LogEntry @relation(fields: [logEntryId], references: [id], onDelete: Cascade)

  @@unique([logEntryId, type, entityId])
  @@index([logEntryId])
  @@index([type, entityId])
}

model Announcement {
  id        String           @id @default(cuid())
  storeId   String?
  authorId  String
  title     String
  body      String
  priority  AnnouncePriority @default(NORMAL)
  expiresAt DateTime?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  store    Store?                @relation(fields: [storeId], references: [id])
  author   User                  @relation(fields: [authorId], references: [id])
  receipts AnnouncementReceipt[]

  @@index([storeId, createdAt])
}

model AnnouncementReceipt {
  id             String    @id @default(cuid())
  announcementId String
  userId         String
  readAt         DateTime?
  acknowledgedAt DateTime?
  createdAt      DateTime  @default(now())

  announcement Announcement @relation(fields: [announcementId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([announcementId, userId])
  @@index([userId, acknowledgedAt])
  @@index([announcementId, acknowledgedAt])
}

enum StockStatus {
  IN_STOCK
  LOW
  OUT_OF_STOCK
}

enum ChecklistItemStatus {
  DONE
  SKIPPED
  NOT_APPLICABLE
}

model Category {
  id                   String   @id @default(cuid())
  storeId              String
  name                 String
  defaultMarkupPercent Decimal  @default(30)
  sortOrder            Int      @default(0)
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())

  store    Store     @relation(fields: [storeId], references: [id])
  products Product[]

  @@unique([storeId, name])
  @@index([storeId, sortOrder])
}

model Product {
  id              String      @id @default(cuid())
  storeId         String
  categoryId      String?
  name            String
  brand           String?
  size            String?
  unit            String?
  barcode         String?
  sku             String?
  costPrice       Decimal
  retailPrice     Decimal
  markupPercent   Decimal
  useCustomMarkup Boolean     @default(false)
  location        String?
  supplier        String?
  stockStatus     StockStatus @default(IN_STOCK)
  importSource    String?
  lastImportedAt  DateTime?
  isActive        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  expiryAlerts    ExpiryAlert[]
  stockOutReports StockOutReport[]

  @@unique([storeId, barcode])
  @@index([storeId, name])
  @@index([storeId, sku])
  @@index([storeId, brand])
  @@index([storeId, categoryId])
}

model ChecklistTemplate {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store       Store                  @relation(fields: [storeId], references: [id])
  items       ChecklistTemplateItem[]
  submissions ChecklistSubmission[]

  @@index([storeId])
}

model ChecklistTemplateItem {
  id         String  @id @default(cuid())
  templateId String
  label      String
  sortOrder  Int     @default(0)
  isRequired Boolean @default(true)

  template        ChecklistTemplate       @relation(fields: [templateId], references: [id], onDelete: Cascade)
  submissionItems ChecklistSubmissionItem[]

  @@index([templateId, sortOrder])
}

model ChecklistSubmission {
  id            String   @id @default(cuid())
  storeId       String
  templateId    String
  submittedById String
  date          DateTime @db.Date
  completedAt   DateTime @default(now())
  notes         String?

  store       Store              @relation(fields: [storeId], references: [id])
  template    ChecklistTemplate  @relation(fields: [templateId], references: [id])
  submittedBy User               @relation(fields: [submittedById], references: [id])
  items       ChecklistSubmissionItem[]

  @@unique([storeId, templateId, date])
  @@index([storeId, date])
}

model ChecklistSubmissionItem {
  id             String              @id @default(cuid())
  submissionId   String
  templateItemId String?
  status         ChecklistItemStatus
  reason         String?
  label          String?

  submission   ChecklistSubmission    @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  templateItem ChecklistTemplateItem? @relation(fields: [templateItemId], references: [id], onDelete: SetNull)

  @@index([submissionId])
}

enum ExpiryStatus {
  ACTIVE
  PULLED
  RESOLVED
}

enum StockOutStatus {
  REPORTED
  ACKNOWLEDGED
  RESTOCKED
}

enum IncidentCategory {
  EQUIPMENT
  SAFETY
  CUSTOMER
  THEFT
  MAINTENANCE
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model ExpiryAlert {
  id           String       @id @default(cuid())
  storeId      String
  productId    String?
  productName  String
  expiryDate   DateTime     @db.Date
  quantity     Int          @default(1)
  location     String?
  reportedById String
  status       ExpiryStatus @default(ACTIVE)
  resolvedAt   DateTime?
  createdAt    DateTime     @default(now())

  store      Store    @relation(fields: [storeId], references: [id])
  product    Product? @relation(fields: [productId], references: [id])
  reportedBy User     @relation("ExpiryReporter", fields: [reportedById], references: [id])

  @@index([storeId, status, expiryDate])
}

model StockOutReport {
  id           String         @id @default(cuid())
  storeId      String
  productId    String?
  productName  String
  location     String?
  reportedById String
  status       StockOutStatus @default(REPORTED)
  resolvedAt   DateTime?
  resolvedById String?
  notes        String?
  createdAt    DateTime       @default(now())

  store      Store    @relation(fields: [storeId], references: [id])
  product    Product? @relation(fields: [productId], references: [id])
  reportedBy User     @relation("StockOutReporter", fields: [reportedById], references: [id])
  resolvedBy User?    @relation("StockOutResolver", fields: [resolvedById], references: [id])

  @@index([storeId, status])
  @@index([storeId, createdAt])
}

model Incident {
  id           String           @id @default(cuid())
  storeId      String
  reportedById String
  category     IncidentCategory
  title        String
  description  String
  severity     IncidentSeverity @default(MEDIUM)
  photoUrl     String?
  status       IncidentStatus   @default(OPEN)
  resolvedAt   DateTime?
  resolvedById String?
  resolution   String?
  createdAt    DateTime         @default(now())

  store      Store @relation(fields: [storeId], references: [id])
  reportedBy User  @relation("IncidentReporter", fields: [reportedById], references: [id])
  resolvedBy User? @relation("IncidentResolver", fields: [resolvedById], references: [id])

  @@index([storeId, status])
  @@index([storeId, createdAt])
}

enum ScheduleStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AbsenceType {
  VACATION_LEAVE
  SICK_LEAVE
  MATERNITY_LEAVE
  PERSONAL_LEAVE
  OTHER
}

model StaffAvailability {
  id        String  @id @default(cuid())
  userId    String
  dayOfWeek Int
  available Boolean @default(true)
  note      String?

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, dayOfWeek])
  @@index([userId])
}

model StaffAbsence {
  id          String      @id @default(cuid())
  storeId     String
  userId      String
  startDate   DateTime    @db.Date
  endDate     DateTime    @db.Date
  type        AbsenceType
  note        String?
  createdById String
  createdAt   DateTime    @default(now())

  store     Store @relation(fields: [storeId], references: [id])
  user      User  @relation("StaffAbsenceUser", fields: [userId], references: [id], onDelete: Cascade)
  createdBy User  @relation("StaffAbsenceCreator", fields: [createdById], references: [id])

  @@index([storeId, startDate, endDate])
  @@index([userId, startDate, endDate])
}

model ShiftSchedule {
  id            String         @id @default(cuid())
  storeId       String
  weekStart     DateTime       @db.Date
  status        ScheduleStatus @default(DRAFT)
  generatedBy   String?
  aiPrompt      String?
  aiResponse    String?
  publishedAt   DateTime?
  publishedById String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  store       Store       @relation(fields: [storeId], references: [id])
  publishedBy User?       @relation("SchedulePublisher", fields: [publishedById], references: [id])
  slots       ShiftSlot[]

  @@unique([storeId, weekStart])
  @@index([storeId, weekStart])
}

model ShiftSlot {
  id         String   @id @default(cuid())
  scheduleId String
  userId     String
  date       DateTime @db.Date
  startTime  String
  endTime    String
  role       String

  schedule ShiftSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  user     User          @relation(fields: [userId], references: [id])

  @@index([scheduleId, date])
  @@index([userId, date])
}

enum POStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum PromotionType {
  WEEKLY_SPECIAL
  CLEARANCE
  SEASONAL
  BUNDLE
  OTHER
}

enum SuggestionCategory {
  GENERAL
  SAFETY
  SCHEDULE
  EQUIPMENT
  PROCESS
  OTHER
}

enum SuggestionStatus {
  NEW
  REVIEWED
  IMPLEMENTED
  DISMISSED
}

enum NotificationType {
  TASK_ASSIGNED
  TASK_UPDATED
  THREAD_MENTION
  THREAD_REPLY
  THREAD_URGENT
  ANNOUNCEMENT
  SCHEDULE_PUBLISHED
  STOCK_OUT
  INCIDENT
  SUGGESTION_RESPONSE
  GENERAL
}

model Supplier {
  id        String   @id @default(cuid())
  storeId   String
  name      String
  contact   String?
  phone     String?
  email     String?
  notes     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  store  Store           @relation(fields: [storeId], references: [id])
  orders PurchaseOrder[]

  @@unique([storeId, name])
  @@index([storeId])
}

model PurchaseOrder {
  id           String   @id @default(cuid())
  storeId      String
  supplierId   String
  orderNumber  String
  status       POStatus @default(DRAFT)
  totalAmount  Decimal?
  notes        String?
  orderedAt    DateTime?
  expectedAt   DateTime?
  receivedAt   DateTime?
  createdById  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  store     Store               @relation(fields: [storeId], references: [id])
  supplier  Supplier            @relation(fields: [supplierId], references: [id])
  createdBy User                @relation("POCreator", fields: [createdById], references: [id])
  items     PurchaseOrderItem[]

  @@unique([storeId, orderNumber])
  @@index([storeId, status])
  @@index([storeId, createdAt])
}

model PurchaseOrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productName String
  quantity    Int
  unitCost    Decimal
  receivedQty Int?
  notes       String?

  order PurchaseOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
}

model Promotion {
  id          String        @id @default(cuid())
  storeId     String
  title       String
  description String?
  type        PromotionType
  startDate   DateTime      @db.Date
  endDate     DateTime      @db.Date
  isActive    Boolean       @default(true)
  createdById String
  createdAt   DateTime      @default(now())

  store     Store           @relation(fields: [storeId], references: [id])
  createdBy User            @relation("PromotionCreator", fields: [createdById], references: [id])
  items     PromotionItem[]

  @@index([storeId, isActive])
  @@index([storeId, startDate])
}

model PromotionItem {
  id            String  @id @default(cuid())
  promotionId   String
  productName   String
  originalPrice Decimal
  promoPrice    Decimal
  notes         String?

  promotion Promotion @relation(fields: [promotionId], references: [id], onDelete: Cascade)

  @@index([promotionId])
}

model SOPGuide {
  id          String    @id @default(cuid())
  storeId     String?
  title       String
  description String?
  category    String
  isPublished Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  store     Store?    @relation(fields: [storeId], references: [id])
  createdBy User      @relation("SOPCreator", fields: [createdById], references: [id])
  steps     SOPStep[]

  @@index([storeId, category])
}

model SOPStep {
  id         String @id @default(cuid())
  guideId    String
  stepNumber Int
  title      String
  content    String
  imageUrl   String?

  guide SOPGuide @relation(fields: [guideId], references: [id], onDelete: Cascade)

  @@index([guideId, stepNumber])
}

model Suggestion {
  id            String             @id @default(cuid())
  storeId       String
  body          String
  category      SuggestionCategory @default(GENERAL)
  isAnonymous   Boolean            @default(true)
  authorId      String?
  status        SuggestionStatus   @default(NEW)
  response      String?
  respondedById String?
  respondedAt   DateTime?
  createdAt     DateTime           @default(now())

  store       Store  @relation(fields: [storeId], references: [id])
  author      User?  @relation("SuggestionAuthor", fields: [authorId], references: [id])
  respondedBy User?  @relation("SuggestionResponder", fields: [respondedById], references: [id])

  @@index([storeId, status])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  link      String?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, isRead, createdAt])
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model NotificationPreference {
  id                    String   @id @default(cuid())
  userId                String   @unique
  threadMentions        Boolean  @default(true)
  threadReplies         Boolean  @default(true)
  urgentThreads         Boolean  @default(true)
  taskAlerts            Boolean  @default(true)
  announcementAlerts    Boolean  @default(true)
  scheduleAlerts        Boolean  @default(true)
  stockAlerts           Boolean  @default(true)
  incidentAlerts        Boolean  @default(true)
  suggestionResponses   Boolean  @default(true)
  urgentOverrideQuiet   Boolean  @default(true)
  quietHoursStart       String?
  quietHoursEnd         String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AppSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  updatedById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  updatedBy User? @relation("AppSettingUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([updatedById])
}

model AdminActionLog {
  id         String   @id @default(cuid())
  storeId    String?
  actorId    String
  action     String
  sourceType String?
  sourceId   String?
  scope      String
  note       String?
  metadata   Json?
  createdAt  DateTime @default(now())

  store Store? @relation(fields: [storeId], references: [id])
  actor User   @relation("AdminActionActor", fields: [actorId], references: [id])

  @@index([storeId, createdAt])
  @@index([actorId, createdAt])
  @@index([sourceType, sourceId])
}
